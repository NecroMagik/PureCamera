<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- TextureView для превью камеры -->
    <TextureView
        android:id="@+id/textureView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Нижняя панель с элементами управления -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Кнопка спуска -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/captureButton"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginEnd="32dp"
            android:clickable="false"
            android:enabled="false"
            android:src="@android:drawable/ic_menu_camera"
            app:backgroundTint="?attr/colorPrimary"
            app:tint="?attr/colorOnPrimary" />

        <!-- Превью последнего фото -->
        <ImageView
            android:id="@+id/lastPhotoPreview"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/photo_frame_border"
            android:padding="2dp"
            android:scaleType="centerCrop"
            android:contentDescription="@string/last_photo_preview" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>